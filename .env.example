# Telegram bot token (https://t.me/BotFather)
BOT_TOKEN=

# SQLite DB path (relative to project root)
DATABASE_URL=sqlite+aiosqlite:///./dietary_coach.db

# Logging level
LOG_LEVEL=INFO

# Optional proxy for Telegram API (если api.telegram.org недоступен напрямую).
# Поддерживаются http://, https://, socks5:// (для socks нужен пакет aiohttp-socks).
# Если PROXY_URL не задан, автоматически берутся HTTPS_PROXY / HTTP_PROXY из окружения.
# Примеры:
#   PROXY_URL=http://user:pass@127.0.0.1:8888
#   PROXY_URL=socks5://127.0.0.1:1080
PROXY_URL=
